# ═══════════════════════════════════════════════════════════
# CESAROPS Core — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── AI / LLM ──────────────────────────────────────────────
# Qwen (DashScope) API key for AI Director & LLM features
# Get one at: https://dashscope.console.aliyun.com/
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── NASA Earthdata (SWOT, ICESat-2, Landsat) ─────────────
# Get one at: https://urs.earthdata.nasa.gov/
EARTHDATA_TOKEN=
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# ── USGS Earth Explorer (Landsat archives) ───────────────
# Get one at: https://earthexplorer.usgs.gov/
USGS_API_KEY=

# ── Copernicus / Sentinel (Sentinel-1 SAR, Sentinel-2) ───
# Get one at: https://dataspace.copernicus.eu/
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# ── Remote Nodes (Pi & Xenon) ────────────────────────────
PI_HOST=10.0.0.100
PI_USER=pi
PI_PASS=
PI_KEY=
PI_WORK=/home/pi/cesarops/sync

XENON_HOST=10.0.0.40
XENON_USER=cesarops
XENON_PASS=
XENON_KEY=
XENON_WORK=/home/cesarops/cesarops/sync

# ── TPU Server ────────────────────────────────────────────
TPU_SERVER_URL=http://localhost:5001

# ── Cloudflare Worker (command queue) ─────────────────────
CLOUDFLARE_API=https://your-worker.your-subdomain.workers.dev

# ── Data Paths ────────────────────────────────────────────
# Base directory for satellite imagery cache
DATA_BASE=C:\Users\thomf\programming\cesarops-wreckhunter build\wreckhunter2000\data\cache\census_raw
LANDSAT_DIR=${DATA_BASE}\2021_low_water
SENTINEL_DIR=${DATA_BASE}\2025_rossa

# ── Drive / Database ──────────────────────────────────────
DRIVE_PATH=C:\Users\thomf\programming\cesarops-wreckhunter build\wreckhunter2000
DB_PATH=${DRIVE_PATH}\LAKE_MICHIGAN_CENSUS_2026.db
